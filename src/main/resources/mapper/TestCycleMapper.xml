<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.TestCycleMapper">

    <resultMap id="BaseResultMap" type="com.example.demo.entity.TestCycle">
        <id column="id" property="id"/>
        <result column="cycle_code" property="cycleCode"/>
        <result column="cycle_name" property="cycleName"/>
        <result column="condition_no" property="conditionNo"/>
        <result column="engine_speed" property="engineSpeed"/>
        <result column="power_mode" property="powerMode"/>
        <result column="weight_coefficient" property="weightCoefficient"/>
        <result column="is_deleted" property="isDeleted"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="delete_time" property="deleteTime"/>
    </resultMap>

    <select id="selectByCycleCode" resultMap="BaseResultMap">
        SELECT * FROM test_cycle
        WHERE cycle_code = #{cycleCode} AND is_deleted = 0
        ORDER BY condition_no ASC, sort ASC
    </select>

</mapper>
